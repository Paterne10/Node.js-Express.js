<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<title>Welcome — Nexus</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500&display=swap');

  :root {
    --bg:          #0f1117;
    --panel:       #181b26;
    --border:      #252836;
    --text:        #eef0f6;
    --muted:       #7c8099;
    --accent:      #7c9eff;
    --accent-dim:  rgba(124,158,255,0.12);
    --danger:      #f87171;
    --danger-dim:  rgba(248,113,113,0.10);
    --danger-border: rgba(248,113,113,0.28);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    background: var(--bg);
    font-family: 'Inter', sans-serif;
    color: var(--text);
  }

  /* ── Top bar ── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    border-bottom: 1px solid var(--border);
    background: var(--panel);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 700;
  }

  .logo-mark {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-mark i { font-size: 15px; color: #0c0e14; }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .user-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1e2130;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 5px 14px 5px 6px;
  }

  .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent-dim);
    border: 1px solid rgba(124,158,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 500;
    color: var(--accent);
    flex-shrink: 0;
  }

  .user-pill span {
    font-size: 13px;
    color: var(--text);
  }

  .logout-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 7px 13px;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    color: var(--muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .logout-btn:hover {
    color: var(--danger);
    border-color: var(--danger-border);
  }

  /* ── Body ── */
  .body {
    max-width: 860px;
    margin: 0 auto;
    padding: 40px 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ── Hero card ── */
  .hero {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .avatar-lg {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-dim);
    border: 1px solid rgba(124,158,255,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 500;
    color: var(--accent);
    flex-shrink: 0;
  }

  .hero-text h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 5px;
  }

  .hero-text p {
    font-size: 13px;
    color: var(--muted);
  }

  /* ── Stat cards ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .card-icon {
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon i { font-size: 18px; color: var(--accent); }

  .card-label {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .topbar { padding: 14px 16px; }
    .body { padding: 24px 16px; }
    .cards { grid-template-columns: 1fr; }
    .hero { flex-direction: column; text-align: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .logout-btn { transition: none; }
  }
</style>
</head>
<body>

<!-- Top bar -->
<div class="topbar">
  <div class="logo">
    <div class="logo-mark"><i class="ti ti-bolt" aria-hidden="true"></i></div>
    Nexus
  </div>

  <div class="topbar-right">
    <div class="user-pill">
      <div class="avatar" id="avatarInitials"></div>
      <span id="userName"></span>
    </div>
    <a href="/logout" style="text-decoration:none;">
      <button class="logout-btn">
        <i class="ti ti-logout" aria-hidden="true"></i>
        Log out
      </button>
    </a>
  </div>
</div>

<!-- Body -->
<div class="body">

  <!-- Hero -->
  <div class="hero">
    <div class="avatar-lg" id="avatarLg"></div>
    <div class="hero-text">
      <h1 id="heroGreeting"></h1>
      <p id="heroSub"></p>
    </div>
  </div>

  <!-- Stat cards -->
  <div class="cards">
    <div class="card">
      <div class="card-icon"><i class="ti ti-layout-dashboard" aria-hidden="true"></i></div>
      <p class="card-label">Projects</p>
      <p class="card-value">12</p>
    </div>
    <div class="card">
      <div class="card-icon"><i class="ti ti-users" aria-hidden="true"></i></div>
      <p class="card-label">Team members</p>
      <p class="card-value">5</p>
    </div>
    <div class="card">
      <div class="card-icon"><i class="ti ti-chart-bar" aria-hidden="true"></i></div>
      <p class="card-label">Tasks done</p>
      <p class="card-value">48</p>
    </div>
  </div>

</div>

<script>
  const name  = "<%= user.name %>";
  const mail  = "<%= user.mail %>";
  const initials = name.split(" ").map(w => w[0]).join("").toUpperCase().slice(0, 2);

  document.getElementById("avatarInitials").textContent = initials;
  document.getElementById("avatarLg").textContent       = initials;
  document.getElementById("userName").textContent        = name;
  document.getElementById("heroGreeting").textContent    = "Welcome back, " + name.split(" ")[0] + " 👋";
  document.getElementById("heroSub").textContent         = mail + " · Signed in with Google";
</script>

</body>
</html>
