<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Sortie — find your next thing to do</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="styles/activity.css">
</head>
<body>

<div class="app">

  <header class="header">
    <div class="wordmark">sortie</div>
    <div class="badge">prototype</div>
  </header>

  <section class="hero">
    <p class="eyebrow">Plan an outing</p>
    <h1>What should<br>we do?</h1>
    <p class="hero-sub">Pick a type of activity and how many of you there are — we'll match you with something worth doing.</p>
  </section>

  <section class="field">
    <p class="field-label">Activity type</p>
    <!-- Fixed set of types, defined here in the front-end -->
    <div class="chips" id="chips">
      <button class="chip chip--outdoor active" data-type="outdoor">
        <svg class="chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l4 6H8l4-6z"/><path d="M12 9l5 7H7l5-7z"/><path d="M12 16v5"/></svg>
        Outdoor
      </button>
      <button class="chip chip--sports" data-type="sports">
        <svg class="chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M4 12h16M12 4c2.5 2.5 2.5 13 0 16M12 4c-2.5 2.5-2.5 13 0 16"/></svg>
        Sports
      </button>
      <button class="chip chip--creative" data-type="creative">
        <svg class="chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 100 18c1.2 0 1.6-.8 1.6-1.5s-.4-1-.4-1.7c0-1 .8-1.8 1.8-1.8h1.5A3.5 3.5 0 0021 12.5C21 7.3 17 3 12 3z"/><circle cx="8" cy="11" r="1"/><circle cx="12" cy="8" r="1"/><circle cx="16" cy="11" r="1"/></svg>
        Creative
      </button>
      <button class="chip chip--food" data-type="food">
        <svg class="chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3v7a2 2 0 002 2v9M7 3v9M11 3v9M15 3c-1.2 1.5-1.2 6.5 0 8s1.2 6.5 0 9"/></svg>
        Food &amp; drink
      </button>
      <button class="chip chip--games" data-type="games">
        <svg class="chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="3"/><circle cx="9" cy="9" r="1"/><circle cx="15" cy="15" r="1"/></svg>
        Games
      </button>
      <button class="chip chip--chill" data-type="chill">
        <svg class="chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 11V7a4 4 0 018 0v4M4 11h16l-1.2 7a2 2 0 01-2 1.7H7.2a2 2 0 01-2-1.7L4 11z"/></svg>
        Chill
      </button>
    </div>
  </section>

  <section class="field">
    <p class="field-label">How many of you</p>
    <div class="stepper-row">
      <div class="stepper">
        <button class="stepper-btn" id="dec" aria-label="Decrease">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/></svg>
        </button>
        <span class="stepper-count" id="count">2</span>
        <button class="stepper-btn" id="inc" aria-label="Increase">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        </button>
      </div>
      <span class="people-hint" id="peopleHint">just the two of you</span>
    </div>
  </section>

  <section class="cta-block">
    <button class="cta" id="findBtn">
      Find us something
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </button>
    <p class="cta-note" id="ctaNote"></p>
  </section>

  <!-- Example result card, shown here for the visual — this section will be
       populated dynamically once the API response comes back. -->
  <section class="result-wrap" id="resultWrap">
    <div class="result-card">
      <div class="result-top">
        <div class="result-icon result-icon--outdoor">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l4 6H8l4-6z"/><path d="M12 9l5 7H7l5-7z"/><path d="M12 16v5"/></svg>
        </div>
        <h3 class="result-name">Sunset hike to the overlook</h3>
      </div>
      <p class="result-desc">A moderate trail with a payoff view — good for catching golden hour together.</p>
      <div class="result-tags">
        <span class="tag">2–3 hrs</span>
        <span class="tag">Medium energy</span>
        <span class="tag">1–8 people</span>
      </div>
      <button class="again" id="againBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0114-5.3M20 12a8 8 0 01-14 5.3M4 4v5h5M20 20v-5h-5"/></svg>
        Try another
      </button>
    </div>
  </section>

  <footer class="footer">front-end prototype · matching data comes from the API</footer>

</div>

<!-- script.js will go here once we wire up the API call -->

</body>
</html>
